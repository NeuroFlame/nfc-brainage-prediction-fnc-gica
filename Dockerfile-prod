FROM python:3.8-bullseye

# Upgrade pip and setuptools
RUN python3 -m pip install -U pip
RUN python3 -m pip install -U setuptools

# Set working directory
WORKDIR /workspace/

# Copy the requirements.txt file
COPY ./requirements.txt /workspace/requirements.txt

# Install dependencies from requirements.txt (includes nvflare==2.4.0 and cryptography==42.0.5)
RUN python3 -m pip install -r /workspace/requirements.txt

# Patch nvflare's cert.py to fix missing pkcs12 attribute on older cryptography.
# cryptography>=3.5 has the pkcs12 submodule but doesn't auto-attach it to the
# serialization namespace in all versions. The nvflare CLI runs as a subprocess
# so the fix must be applied on disk.
RUN CERT=/usr/local/lib/python3.8/site-packages/nvflare/lighter/impl/cert.py && \
    sed -i 's/^from cryptography.hazmat.primitives import hashes, serialization$/from cryptography.hazmat.primitives import hashes, serialization\ntry:\n    _ = serialization.pkcs12\nexcept AttributeError:\n    from cryptography.hazmat.primitives.serialization import pkcs12 as _pkcs12\n    serialization.pkcs12 = _pkcs12/' "$CERT"

# Copy the rest of the application files
COPY ./app/ /workspace/app/
COPY ./system/entry_central.py /workspace/system/entry_central.py
COPY ./system/entry_edge.py /workspace/system/entry_edge.py
COPY ./system/provision/ /workspace/system/provision/
COPY ./system/entry_provision.py /workspace/system/entry_provision.py

# Set environment variables
ENV PYTHONPATH=/workspace/app/code/
ENV DATA_DIR=/workspace/data/
ENV OUTPUT_DIR=/workspace/output/
ENV PARAMETERS_FILE_PATH=/workspace/runKit/parameters.json
